# --- Required for M1 (marketing + builder signup) ---

# Postgres (Neon recommended)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DATABASE_URL_DIRECT=postgresql://user:pass@host/db?sslmode=require

# Auth.js — `openssl rand -base64 32` for the secret
AUTH_SECRET=

# GitHub OAuth app — primary provider for builders
# https://github.com/settings/applications/new
# Authorization callback URL: ${NEXT_PUBLIC_APP_URL}/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Resend — magic-link sign-in
# https://resend.com — domain auth required for production
RESEND_API_KEY=
RESEND_FROM_EMAIL="ClawCruise <hello@mail.codecruise.events>"

# Public app URL (used for OAuth callback URLs in dev)
NEXT_PUBLIC_APP_URL=http://localhost:3030


# --- Optional for M1, required for M2 ---

# Upstash Redis — BullMQ queues + worker, AI judge pipeline
REDIS_URL=

# Nebius Token Factory — LLM calls for the AI judge
NEBIUS_TOKEN_FACTORY_KEY=
NEBIUS_TOKEN_FACTORY_BASE_URL=https://api.studio.nebius.ai/v1
NEBIUS_JUDGE_MODEL=Qwen/Qwen2.5-72B-Instruct-fast

# Composio — verify integrations claimed in submissions
COMPOSIO_API_KEY=

# Tavily — search API for fact-checking
TAVILY_API_KEY=

# GitHub App — repo snapshot for AI judge
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=

# Discord — notifications
DISCORD_WEBHOOK_URL=

# Pusher — live leaderboard on May 30
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=us2
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=us2

# Cloudflare R2 — project video uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=codecruise
R2_PUBLIC_BASE_URL=

# Optional auth providers (enable any)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_LINKEDIN_ID=
AUTH_LINKEDIN_SECRET=

# Telemetry
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=
NEXT_PUBLIC_POSTHOG_KEY=
