{
  "name": "codecruise",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3030",
    "build": "next build",
    "start": "next start -p 3030",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/server/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/server/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "worker": "tsx watch src/server/workers/index.ts",
    "worker:start": "node dist/workers/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "next": "14.2.18",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "clsx": "2.1.1",
    "tailwind-merge": "2.5.4",
    "@trpc/server": "^11.0.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/next": "^11.0.0",
    "@tanstack/react-query": "^5.59.16",
    "next-auth": "5.0.0-beta.22",
    "@auth/drizzle-adapter": "1.7.2",
    "drizzle-orm": "0.36.1",
    "drizzle-zod": "0.5.1",
    "@neondatabase/serverless": "0.10.3",
    "postgres": "3.4.5",
    "bullmq": "5.21.2",
    "ioredis": "5.4.1",
    "zod": "3.23.8",
    "resend": "4.0.1",
    "@react-email/components": "0.0.28",
    "pusher": "^5.2.0",
    "pusher-js": "^8.4.0",
    "@aws-sdk/client-s3": "3.687.0",
    "@aws-sdk/s3-request-presigner": "3.687.0",
    "@octokit/app": "15.1.0",
    "@octokit/rest": "21.0.2",
    "@octokit/webhooks": "13.4.1",
    "rrule": "^2.8.1",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "superjson": "2.2.1",
    "server-only": "0.0.1"
  },
  "devDependencies": {
    "@types/node": "20.16.10",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.47",
    "tailwindcss": "3.4.13",
    "typescript": "5.6.2",
    "drizzle-kit": "0.28.0",
    "tsx": "4.19.1",
    "vitest": "2.1.4",
    "@vitest/coverage-v8": "2.1.4",
    "@playwright/test": "1.48.2",
    "@testcontainers/postgresql": "10.13.2",
    "msw": "2.6.4"
  }
